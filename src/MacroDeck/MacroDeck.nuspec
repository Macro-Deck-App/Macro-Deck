<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>SuchByte.MacroDeck</id>
    <version>$version$</version>
    <authors>Manuel Mayer</authors>
    <owners>Macro Deck</owners>
    <projectUrl>https://github.com/Macro-Deck-App/Macro-Deck</projectUrl>
    <license type="expression">Apache-2.0</license>
    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>API assembly for developing Macro Deck plugins. This is a compile-time reference package; the assembly is provided by the Macro Deck host at runtime.</description>
    <tags>macrodeck macro-deck plugin api</tags>
    <repository type="git" url="https://github.com/Macro-Deck-App/Macro-Deck" />
    <!-- No runtime dependencies: the host provides everything the plugin needs. -->
    <dependencies>
      <group targetFramework="net10.0-windows" />
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="" />
    <!-- Shipped under ref/ only: plugins compile against the API, but the
         assembly is NOT copied to the plugin output. The Macro Deck host
         already has "Macro Deck 2.dll" loaded at runtime. -->
    <file src="bin\Release\Macro Deck 2.dll" target="ref\net10.0-windows" />
  </files>
</package>
